# ============================================
# Application Settings
# ============================================
DEBUG=false
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ============================================
# LLM Configuration
# Anthropic API (for LangChain)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# ============================================
# Feature Flags
# ============================================
ENABLE_MCP=false
ENABLE_SKILLS=true

# ============================================
# Session Configuration
# ============================================
SESSION_BACKEND=redis
SESSION_MAX_AGE_DAYS=7
SESSION_MAX_RUNS_PER_SESSION=100
SESSION_TITLE_MODEL=claude-3-5-haiku-20241022
SESSION_TITLE_PROMPT=Generate a short title (max 10 words) for this conversation.

ENABLE_MESSAGE_HISTORY=true
SSE_CACHE_TTL=3600  # Redis TTL for SSE events (1 hour)
MAX_EVENTS_PER_SESSION=10000

# ============================================
# Redis Configuration
# ============================================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=  # Optional: Redis password if authentication is enabled

# ============================================
# MongoDB Configuration
# ============================================
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=agent_state
MONGODB_ENABLED=true
MONGODB_USERNAME=  # Optional: MongoDB username
MONGODB_PASSWORD=  # Optional: MongoDB password
MONGODB_AUTH_SOURCE=admin
MONGODB_MESSAGES_COLLECTION=messages
MONGODB_SESSIONS_COLLECTION=sessions
MONGODB_EVENTS_COLLECTION=sse_events
MONGODB_TRACES_COLLECTION=traces

# ============================================
# Sandbox Configuration
# ============================================
# Supported platforms: runloop, daytona, modal
SANDBOX_PLATFORM=runloop

# Runloop Configuration
RUNLOOP_API_KEY=
RUNLOOP_BASE_URL=https://api.runloop.ai

# Daytona Configuration
DAYTONA_API_KEY=
DAYTONA_SERVER_URL=
DAYTONA_TIMEOUT=180  # Command timeout in seconds (default: 3 minutes)

# Modal Configuration
MODAL_APP_NAME=

# ============================================
# Skills Configuration
# ============================================
SKILLS_DIR=./skills
USER_SKILLS_DIR=  # Optional: User-level skills directory (e.g., ~/.lamb-agent/skills)
SKILLS_MONGODB_ENABLED=false  # Enable MongoDB storage for skills
SKILLS_MONGODB_COLLECTION=skills

# ============================================
# LangSmith Tracing
# ============================================
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=lamb-agent
LANGSMITH_API_URL=https://api.smith.langchain.com
LANGSMITH_SAMPLE_RATE=1.0

# ============================================
# JWT Authentication
# ============================================
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=24
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# S3 Storage Configuration
# ============================================
S3_ENABLED=false
S3_PROVIDER=aws  # aws, aliyun, tencent, minio, custom
S3_ENDPOINT_URL=  # Required for MinIO and custom providers
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_REGION=us-east-1
S3_BUCKET_NAME=your-bucket-name
S3_CUSTOM_DOMAIN=  # Optional: Custom CDN domain
S3_PATH_STYLE=false  # Required for MinIO
S3_MAX_FILE_SIZE=10485760  # Maximum file size in bytes (default: 10MB)
S3_PUBLIC_BUCKET=false
S3_PRESIGNED_URL_EXPIRES=604800  # Presigned URL expiration in seconds (default: 7 days)

# ============================================
# Frontend Settings
# ============================================
DEFAULT_AGENT=default
DEFAULT_USER_ROLE=user
CHUNK_BATCH_INTERVAL=50
MAX_PROCESSED_IDS=1000
