# ============================================
# Application Settings
# ============================================
DEBUG=false
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ============================================
# LLM Configuration
# ============================================
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=your_openai_api_key_here
LLM_MODEL=anthropic/claude-3-5-sonnet-20241022
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
LLM_MAX_RETRIES=3

# Anthropic API (for Claude models)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# ============================================
# Feature Flags
# ============================================
ENABLE_MCP=true
ENABLE_SKILLS=true
ENABLE_SANDBOX=false

# ============================================
# Session Configuration
# ============================================
SESSION_MAX_RUNS_PER_SESSION=100
SESSION_TITLE_MODEL=claude-3-5-haiku-20241022
SESSION_TITLE_PROMPT=Generate a short title (max 10 words) for this conversation.

ENABLE_MESSAGE_HISTORY=true
SSE_CACHE_TTL=3600  # Redis TTL for SSE events (1 hour)

# ============================================
# Redis Configuration
# ============================================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=  # Optional: Redis password if authentication is enabled

# ============================================
# MongoDB Configuration
# ============================================
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=agent_state
MONGODB_USERNAME=  # Optional: MongoDB username
MONGODB_PASSWORD=  # Optional: MongoDB password
MONGODB_AUTH_SOURCE=admin

# ============================================
# Long-term Storage Configuration (PostgreSQL for LangGraph Store)
# ============================================
# Enable PostgreSQL-based long-term storage for agent memories and files
ENABLE_LONG_TERM_STORAGE=false
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=langgraph
POSTGRES_POOL_MIN_SIZE=2
POSTGRES_POOL_MAX_SIZE=10

# ============================================
# Sandbox Configuration
# ============================================
# Supported platforms: runloop, daytona, modal
SANDBOX_PLATFORM=runloop

# Runloop Configuration
RUNLOOP_API_KEY=
RUNLOOP_BASE_URL=https://api.runloop.ai

# Daytona Configuration
DAYTONA_API_KEY=
DAYTONA_SERVER_URL=
DAYTONA_TIMEOUT=180  # Command timeout in seconds (default: 3 minutes)
DAYTONA_IMAGE=  # Optional: sandbox image/snapshot to use for creating sandboxes

# Modal Configuration
MODAL_APP_NAME=

# Sandbox lifecycle settings
SANDBOX_AUTO_STOP_INTERVAL=5  # Auto-stop interval in minutes
SANDBOX_AUTO_ARCHIVE_INTERVAL=5  # Auto-archive interval in minutes
SANDBOX_AUTO_DELETE_INTERVAL=1440  # Auto-delete interval in minutes after being archived

# ============================================
# Skills Configuration
# ============================================
ENABLE_SKILLS=true

# ============================================
# LangSmith Tracing
# ============================================
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=lamb-agent
LANGSMITH_API_URL=https://api.smith.langchain.com
LANGSMITH_SAMPLE_RATE=1.0

# ============================================
# JWT Authentication
# ============================================
# JWT_SECRET_KEY=  # Optional: auto-generated if not set (recommended for production)
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=24
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# S3 Storage Configuration
# ============================================
S3_ENABLED=false
S3_PROVIDER=aws  # aws, aliyun, tencent, minio, custom
S3_ENDPOINT_URL=  # Required for MinIO and custom providers
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_REGION=us-east-1
S3_BUCKET_NAME=your-bucket-name
S3_CUSTOM_DOMAIN=  # Optional: Custom CDN domain
S3_PATH_STYLE=false  # Required for MinIO
S3_MAX_FILE_SIZE=10485760  # Maximum file size in bytes (default: 10MB)
S3_PUBLIC_BUCKET=false
S3_PRESIGNED_URL_EXPIRES=604800  # Presigned URL expiration in seconds (default: 7 days)

# ============================================
# Frontend Settings
# ============================================
DEFAULT_AGENT=default
DEFAULT_USER_ROLE=user
WELCOME_SUGGESTIONS=[{"icon": "🐍", "text": "Create a Python hello world script"}, {"icon": "📁", "text": "List files in the workspace directory"}, {"icon": "📄", "text": "Read the README.md file"}, {"icon": "🔧", "text": "Help me write a shell script"}]
