# ============================================
# Application Settings
# ============================================
DEBUG=false
HOST=0.0.0.0
PORT=8000
APP_BASE_URL=  # e.g. https://lambchat.example.com — 文件 URL 固定前缀（反向代理时必填）
LOG_LEVEL=INFO

# ============================================
# LLM Configuration
# ============================================
LLM_MAX_RETRIES=3
# LLM_MAX_INPUT_TOKENS=  # Optional: context window size for DeepAgent auto-summarization

# ============================================
# Feature Flags
# ============================================
ENABLE_MCP=true
ENABLE_SKILLS=true
ENABLE_SANDBOX=false

# ============================================
# Session Configuration
# ============================================
SESSION_MAX_RUNS_PER_SESSION=100
SESSION_TITLE_MODEL=claude-3-5-haiku-20241022
SESSION_TITLE_API_BASE=  # Optional: separate API base for title generation
SESSION_TITLE_API_KEY=  # Optional: separate API key for title generation
SESSION_TITLE_PROMPT=Generate a short title (max 10 words) for this conversation.

ENABLE_MESSAGE_HISTORY=true
SSE_CACHE_TTL=3600  # Redis TTL for SSE events (1 hour)

# Event Merger
ENABLE_EVENT_MERGER=true
EVENT_MERGE_INTERVAL=300.0  # Merge interval in seconds (default: 5 minutes)

# ============================================
# Redis Configuration
# ============================================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=  # Optional: Redis password if authentication is enabled

# ============================================
# MongoDB Configuration
# ============================================
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=agent_state
MONGODB_USERNAME=  # Optional: MongoDB username
MONGODB_PASSWORD=  # Optional: MongoDB password
MONGODB_AUTH_SOURCE=admin
MONGODB_SESSIONS_COLLECTION=sessions
MONGODB_TRACES_COLLECTION=traces

# ============================================
# Long-term Storage Configuration (PostgreSQL for LangGraph Store)
# ============================================
ENABLE_POSTGRES_STORAGE=false
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=langgraph
POSTGRES_POOL_MIN_SIZE=2
POSTGRES_POOL_MAX_SIZE=10

# ============================================
# Checkpoint Backend Configuration
# ============================================
CHECKPOINT_BACKEND=mongodb  # mongodb or postgres (postgres avoids 16MB limit)

# ============================================
# MCP Configuration
# ============================================
MCP_ENCRYPTION_SALT=  # Optional: auto-generated if not set (recommended for consistency across restarts)

# ============================================
# Sandbox Configuration
# ============================================
# Supported platforms: daytona, e2b
SANDBOX_PLATFORM=daytona

# Daytona Configuration
DAYTONA_API_KEY=
DAYTONA_SERVER_URL=
DAYTONA_TIMEOUT=180  # Command timeout in seconds (default: 3 minutes)
DAYTONA_IMAGE=  # Optional: sandbox image/snapshot to use for creating sandboxes

# E2B Configuration
E2B_API_KEY=
E2B_TEMPLATE=base  # Sandbox template name
E2B_TIMEOUT=3600  # Sandbox timeout in seconds
E2B_AUTO_PAUSE=true  # Pause sandbox on timeout (preserves state) instead of killing
E2B_AUTO_RESUME=true  # Auto-resume paused sandbox on next activity

# Daytona sandbox lifecycle settings
DAYTONA_AUTO_STOP_INTERVAL=5  # Auto-stop interval in minutes
DAYTONA_AUTO_ARCHIVE_INTERVAL=5  # Auto-archive interval in minutes
DAYTONA_AUTO_DELETE_INTERVAL=1440  # Auto-delete interval in minutes after being archived

# ============================================
# LangSmith Tracing
# ============================================
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=lamb-agent
LANGSMITH_API_URL=https://api.smith.langchain.com
LANGSMITH_SAMPLE_RATE=1.0

# ============================================
# JWT Authentication
# ============================================
JWT_SECRET_KEY=  # Optional: auto-generated if not set (recommended for production)
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=24
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# S3 Storage Configuration
# ============================================
S3_ENABLED=false
S3_PROVIDER=aws  # aws, aliyun, tencent, minio, custom
S3_ENDPOINT_URL=  # Required for MinIO and custom providers
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_REGION=us-east-1
S3_BUCKET_NAME=your-bucket-name
S3_CUSTOM_DOMAIN=  # Optional: Custom CDN domain
S3_PATH_STYLE=false  # Required for MinIO
S3_MAX_FILE_SIZE=10485760  # Maximum file size in bytes (default: 10MB)
S3_INTERNAL_UPLOAD_MAX_SIZE=52428800  # Maximum internal upload size in bytes (default: 50MB)
S3_PUBLIC_BUCKET=false
S3_PRESIGNED_URL_EXPIRES=604800  # Presigned URL expiration in seconds (default: 7 days)

# Local Storage (used when S3_ENABLED=false)
LOCAL_STORAGE_PATH=./uploads  # Path for local file storage

# File Upload Limits
FILE_UPLOAD_MAX_SIZE_IMAGE=10  # Maximum image file size in MB
FILE_UPLOAD_MAX_SIZE_VIDEO=100  # Maximum video file size in MB
FILE_UPLOAD_MAX_SIZE_AUDIO=50  # Maximum audio file size in MB
FILE_UPLOAD_MAX_SIZE_DOCUMENT=50  # Maximum document file size in MB
FILE_UPLOAD_MAX_FILES=10  # Maximum number of files per upload

# ============================================
# User Management
# ============================================
DEFAULT_USER_ROLE=user
ENABLE_REGISTRATION=true

# ============================================
# Cloudflare Turnstile (CAPTCHA)
# ============================================
TURNSTILE_ENABLED=false
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_REQUIRE_ON_LOGIN=false
TURNSTILE_REQUIRE_ON_REGISTER=true
TURNSTILE_REQUIRE_ON_PASSWORD_CHANGE=true

# ============================================
# Email Configuration (Resend)
# ============================================
EMAIL_ENABLED=false
RESEND_ACCOUNTS=[]  # JSON array: [{"api_key": "...", "from": "noreply@example.com"}]
PASSWORD_RESET_EXPIRE_HOURS=24
REQUIRE_EMAIL_VERIFICATION=false

# ============================================
# Memory Settings (Cross-session Memory)
# ============================================
ENABLE_MEMORY=false
MEMORY_PERFORM=memu  # memu, hindsight, or native
HINDSIGHT_BASE_URL=  # e.g., http://localhost:8888
HINDSIGHT_API_KEY=  # Optional: depends on server config
HINDSIGHT_MAX_CONCURRENT=64

# Native Memory Settings (MongoDB-backed, zero external deps)
# NATIVE_MEMORY_EMBEDDING_API_BASE=  # OpenAI-compatible embedding API (empty = text-only)
# NATIVE_MEMORY_EMBEDDING_API_KEY=
# NATIVE_MEMORY_EMBEDDING_MODEL=text-embedding-3-small
# NATIVE_MEMORY_STALENESS_DAYS=30
# NATIVE_MEMORY_INDEX_ENABLED=true
# NATIVE_MEMORY_INDEX_CACHE_TTL=300
# NATIVE_MEMORY_MAX_AUTO_RETAIN_PER_DAY=20

# ============================================
# Frontend Settings
# ============================================
DEFAULT_AGENT=default
WELCOME_SUGGESTIONS=[{"icon": "🐍", "text": "Create a Python hello world script"}, {"icon": "📁", "text": "List files in the workspace directory"}, {"icon": "📄", "text": "Read the README.md file"}, {"icon": "🔧", "text": "Help me write a shell script"}]

# ============================================
# OAuth Configuration
# ============================================
# Google OAuth
OAUTH_GOOGLE_ENABLED=false
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# GitHub OAuth
OAUTH_GITHUB_ENABLED=false
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# Apple OAuth
OAUTH_APPLE_ENABLED=false
OAUTH_APPLE_CLIENT_ID=
OAUTH_APPLE_CLIENT_SECRET=
OAUTH_APPLE_TEAM_ID=
OAUTH_APPLE_KEY_ID=
